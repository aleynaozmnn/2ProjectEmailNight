@model Project2_EmailNight.Dtos.ConfirmUserDto
@{
    Layout = null; //Giriş sayfalarında yan menü istemiyoruz
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="~/Templates/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Templates/css/app.css" rel="stylesheet" />
    <link href="~/Templates/css/icons.css" rel="stylesheet" />
    <title>Email Onayı | Wipotter Email</title>
</head>

<body class="bg-login">
    <div class="wrapper">
        <div class="section-authentication-signin d-flex align-items-center justify-content-center my-5">
            <div class="container">
                <div class="row row-cols-1 row-cols-lg-2 row-cols-xl-3">
                    <div class="col mx-auto">
                        <div class="card shadow-lg">
                            <div class="card-body p-4">
                                <div class="text-center mb-4">
                                    <img src="~/Templates/images/logo-icon.png" width="70" alt="" />
                                    <h4 class="mt-3 font-weight-bold">E-Posta Adresini Doğrula</h4>
                                    <p class="text-muted">Lütfen mail adresinize gönderilen 6 haneli kodu aşağıya giriniz.</p>
                                </div>

                                <form method="post">
                                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                                    <div class="mb-3">
                                        <label class="form-label">E-Posta Adresiniz</label>
                                        <input type="email" asp-for="Mail" class="form-control" />
                                        <input type="hidden" name="Mail" value="@Model.Mail" />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">6 Haneli Onay Kodu</label>
                                        <input type="text" asp-for="ConfirmCode" class="form-control" placeholder="000000" maxlength="6" required />
                                    </div>

                                    <div class="d-grid gap-2">
                                        <button type="submit" class="btn btn-primary">Hesabımı Onayla</button>
                                        <a asp-action="CreateUser" class="btn btn-light"><i class='bx bx-arrow-back mr-1'></i>Kayıt Sayfasına Dön</a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>