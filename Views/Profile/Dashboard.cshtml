@* Dashboard: Genel Panel - Full Güncel Versiyon
   Özellikler: Gradient Kartlar, Kategori Şeritleri, Canlı Grafikler
*@

@{
    ViewData["Title"] = "Genel Panel";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">

<div class="card shadow-sm border-0" style="border-radius: 15px; border-top: 4px solid #8833ff !important;">
<div class="container-fluid px-4 py-4 main-content">

    @* --- BAŞLIK BÖLÜMÜ --- *@
    <div class="d-flex align-items-center justify-content-between mb-4 animate-fade-in">
        <div class="d-flex align-items-center">
            <div class="header-icon-box shadow-sm me-3">
                <i class="bx bx-stats fs-4"></i>
            </div>
            <div>
                <h4 class="mb-0 fw-bold page-title">Genel Bakış</h4>
                <p class="text-muted small mb-0">E-posta trafiğinizi ve istatistiklerinizi analiz edin.</p>
            </div>
        </div>
        <div class="date-badge">
            <i class="bx bx-calendar me-2"></i> @DateTime.Now.ToString("dd MMMM yyyy")
        </div>
    </div>

    @* --- 1. SATIR: ANA DURUM KARTLARI (GRADIENT) --- *@
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 stat-card gradient-inbox shadow-sm">
                <div class="card-body p-4 text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 stat-label text-white-50">Gelen Kutusu</p>
                            <h2 class="mb-0 fw-bold stat-number">@ViewBag.InboundCount</h2>
                        </div>
                        <div class="stat-icon-wrap"><i class='bx bx-envelope'></i></div>
                    </div>
                    <div class="mt-3 small text-white-50">
                        <i class='bx bx-trending-up me-1'></i> Aktif mesaj trafiği
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 stat-card gradient-sent shadow-sm">
                <div class="card-body p-4 text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 stat-label text-white-50">Gönderilenler</p>
                            <h2 class="mb-0 fw-bold stat-number">@ViewBag.SentCount</h2>
                        </div>
                        <div class="stat-icon-wrap"><i class='bx bx-paper-plane'></i></div>
                    </div>
                    <div class="mt-3 small text-white-50">
                        <i class='bx bx-check-double me-1'></i> İletilen mesajlar
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 stat-card gradient-draft shadow-sm">
                <div class="card-body p-4 text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 stat-label text-white-50">Taslaklar</p>
                            <h2 class="mb-0 fw-bold stat-number">@ViewBag.DraftCount</h2>
                        </div>
                        <div class="stat-icon-wrap"><i class='bx bx-edit-alt'></i></div>
                    </div>
                    <div class="mt-3 small text-white-50">
                        <i class='bx bx-time-five me-1'></i> Düzenleme bekleyen
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 stat-card gradient-star shadow-sm">
                <div class="card-body p-4 text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 stat-label text-white-50">Yıldızlı</p>
                            <h2 class="mb-0 fw-bold stat-number">@ViewBag.StarredCount</h2>
                        </div>
                        <div class="stat-icon-wrap"><i class='bx bxs-star'></i></div>
                    </div>
                    <div class="mt-3 small text-white-50">
                        <i class='bx bx-bookmark me-1'></i> Önemli işaretli
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- 2. SATIR: KATEGORİ ÖZETİ (RENKLİ ŞERİTLİ KARTLAR) --- *@
    <div class="row g-3 mb-5">
        @{
            var categories = new[] {
                new { Title = "İŞ", Count = ViewBag.WorkCount, Icon = "bx-briefcase", ColorClass = "cat-work" },
                new { Title = "EĞİTİM", Count = ViewBag.EducationCount, Icon = "bx-book", ColorClass = "cat-edu" },
                new { Title = "SOSYAL", Count = ViewBag.SocialCount, Icon = "bx-group", ColorClass = "cat-social" },
                new { Title = "FİNANS", Count = ViewBag.FinanceCount, Icon = "bx-wallet", ColorClass = "cat-finance" },
                new { Title = "ÖNEMLİ", Count = ViewBag.ImportantCount, Icon = "bx-error-circle", ColorClass = "cat-important" },
                new { Title = "DİĞER", Count = ViewBag.OtherCount, Icon = "bx-dots-horizontal", ColorClass = "cat-other" }
                };
        }
        @foreach (var cat in categories)
        {
            <div class="col-6 col-md-4 col-xl-2">
                <div class="card border-0 category-card shadow-sm h-100 @cat.ColorClass">
                    <div class="card-body p-3 text-center">
                        <div class="cat-icon-box mb-2">
                            <i class='bx @cat.Icon'></i>
                        </div>
                        <h4 class="mb-0 fw-bold">@cat.Count</h4>
                        <p class="mb-0 text-muted small fw-bold">@cat.Title</p>
                    </div>
                </div>
            </div>
        }
    </div>

    @* --- 3. SATIR: GRAFİKLER (YENİLENEN ALANLAR) --- *@
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm glass-card p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="fw-bold mb-0 text-dark tracking-wider">HAFTALIK MESAJ TRAFİĞİ</h6>
                    <div class="chart-filter">Son 7 Gün</div>
                </div>
                <div class="chart-container" style="position: relative; height:320px; width:100%">
                    <canvas id="trafficChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm glass-card p-4 h-100">
                <h6 class="fw-bold mb-4 text-dark text-center tracking-wider">KATEGORİ DAĞILIMI</h6>
                <div class="chart-container" style="position: relative; height:320px; width:100%">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Genel Ayarlar */
    body {
        background-color: #f4f7fe !important;
    }

    .main-content {
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* Başlık */
    .header-icon-box {
        background: #fff;
        color: #4e73df;
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
    }

    .date-badge {
        background: #fff;
        padding: 8px 16px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.85rem;
        color: #4e73df;
    }

    /* Gradient Stat Kartları */
    .stat-card {
        border-radius: 20px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-7px);
        }

    .gradient-inbox {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
    }

    .gradient-sent {
        background: linear-gradient(135deg, #0ba360 0%, #3cba92 100%);
    }

    .gradient-draft {
        background: linear-gradient(135deg, #2c3e50 0%, #4b6cb7 100%);
    }

    .gradient-star {
        background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
    }

    .stat-icon-wrap {
        font-size: 3rem;
        opacity: 0.2;
        position: absolute;
        right: 15px;
        bottom: 10px;
    }

    .stat-number {
        font-size: 2.2rem;
    }

    /* Kategori Kartları */
    .category-card {
        border-radius: 16px;
        background: #fff;
        border-left: 5px solid transparent !important;
        transition: 0.3s;
    }

        .category-card:hover {
            transform: scale(1.05);
        }

    .cat-icon-box {
        font-size: 1.5rem;
        width: 45px;
        height: 45px;
        line-height: 45px;
        background: #f8f9fa;
        border-radius: 50%;
        margin: 0 auto;
    }

    .cat-work {
        border-left-color: #4e73df !important;
    }

        .cat-work i {
            color: #4e73df;
        }

    .cat-edu {
        border-left-color: #1cc88a !important;
    }

        .cat-edu i {
            color: #1cc88a;
        }

    .cat-social {
        border-left-color: #36b9cc !important;
    }

        .cat-social i {
            color: #36b9cc;
        }

    .cat-finance {
        border-left-color: #f6c23e !important;
    }

        .cat-finance i {
            color: #f6c23e;
        }

    .cat-important {
        border-left-color: #e74a3b !important;
    }

        .cat-important i {
            color: #e74a3b;
        }

    .cat-other {
        border-left-color: #858796 !important;
    }

        .cat-other i {
            color: #858796;
        }

    /* Grafik Kartları */
    .glass-card {
        border-radius: 20px;
        background: #ffffff;
    }

    .chart-filter {
        background: #f1f3f9;
        color: #4e73df;
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .tracking-wider {
        letter-spacing: 1px;
    }

    /* Animasyon */
    .animate-fade-in {
        animation: fadeIn 0.8s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // --- HAFTALIK TRAFİK GRAFİĞİ ---
        const trafficCtx = document.getElementById('trafficChart').getContext('2d');
        const trafficGradient = trafficCtx.createLinearGradient(0, 0, 0, 400);
        trafficGradient.addColorStop(0, 'rgba(78, 115, 223, 0.4)');
        trafficGradient.addColorStop(1, 'rgba(78, 115, 223, 0)');

        new Chart(trafficCtx, {
            type: 'line',
            data: {
                labels: [@Html.Raw(ViewBag.ChartLabels)],
                datasets: [{
                    label: 'Mesaj Trafiği',
                    data: [@ViewBag.ChartData],
                    borderColor: '#4e73df',
                    borderWidth: 3,
                    backgroundColor: trafficGradient,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#4e73df',
                    pointBorderColor: '#fff',
                    pointRadius: 4
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f2f2f2' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // --- KATEGORİ DAĞILIM GRAFİĞİ ---
        const categoryCtx = document.getElementById('categoryChart').getContext('2d');
        new Chart(categoryCtx, {
            type: 'doughnut',
            data: {
                labels: ['İş', 'Eğitim', 'Sosyal', 'Finans', 'Önemli', 'Diğer'],
                datasets: [{
                    data: [@ViewBag.WorkCount, @ViewBag.EducationCount, @ViewBag.SocialCount, @ViewBag.FinanceCount, @ViewBag.ImportantCount, @ViewBag.OtherCount],
                    backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b', '#858796'],
                    hoverOffset: 15,
                    borderWidth: 0
                }]
            },
            options: {
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                }
            }
        });
    });
</script>